---
layout: default
---
<div class="home-hero">
  <div class="home-hero-split">
    <!-- Left: Photo + Contact + Socials + Links -->
    <div class="home-hero-left">
      {% if page.profile.image %}
        {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
        {%
          include figure.liquid loading="eager" path=profile_image_path class="home-hero-image" sizes="200px" alt="Profile Image"
          cache_bust=true
        %}
      {% endif %}

      {% if page.email or page.location %}
        <div class="home-hero-contact">
          {% if page.email %}
            <a href="mailto:{{ page.email }}">{{ page.email }}</a>
          {% endif %}
          {% if page.location %}
            <span class="location">{{ page.location }}</span>
          {% endif %}
        </div>
      {% endif %}

      {% if page.about_links %}
        <div class="home-hero-links">
          {% for link in page.about_links %}
            <a href="{{ link.url }}" target="_blank" rel="noopener">
              {{ link.title }}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
            </a>
          {% endfor %}
        </div>
      {% endif %}

      {% if page.social_links %}
        <div class="home-hero-social">
          {% for social in page.social_links %}
            <a href="{{ social.url }}" rel="noopener noreferrer" aria-label="{{ social.label }}" title="{{ social.label }}">
              {% if social.icon == 'linkedin' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                  <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
                </svg>
              {% elsif social.icon == 'github' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
                </svg>
              {% endif %}
            </a>
          {% endfor %}
        </div>
      {% endif %}

      {% if page.quick_links %}
        <div class="home-hero-links">
          {% for link in page.quick_links %}
            <a href="{{ link.url }}" target="_blank" rel="noopener">
              {{ link.title }}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
            </a>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- Right: Name, Subtitle, About -->
    <div class="home-hero-right">
      <h1 class="home-hero-name">
        {% if site.title == 'blank' %}
          {{ site.first_name }} {{ site.middle_name }} {{ site.last_name }}
        {% else %}
          {{ site.title }}
        {% endif %}
      </h1>
      <p class="home-hero-subtitle">{{ page.subtitle }}</p>

      {% if content.size > 0 %}
        <div class="home-hero-about">{{ content }}</div>
      {% endif %}
    </div>
  </div>
</div>

<!-- Skills & Interests -->
{% if page.skills or page.interests %}
  <section class="home-section">
    <div class="home-tags-grid">
      {% if page.skills and page.skills.size > 0 %}
        <div class="home-tags-column">
          <h3>Skills</h3>
          <div class="home-tags">
            {% for skill in page.skills %}
              <span class="home-tag">{{ skill }}</span>
            {% endfor %}
          </div>
        </div>
      {% endif %}
      {% if page.interests and page.interests.size > 0 %}
        <div class="home-tags-column">
          <h3>Interests</h3>
          <div class="home-tags">
            {% for interest in page.interests %}
              <span class="home-tag home-tag--outlined">{{ interest }}</span>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>
  </section>
{% endif %}

<!-- GitHub Activity -->
{% if page.github_username %}
  <section class="home-section home-github">
    <h2 class="home-section-title">GitHub Activity</h2>

    <div class="pinned-repos-scroll" id="pinnedRepos">
      <div class="pinned-repos-loading">Loading repositories...</div>
    </div>

    <a href="https://github.com/{{ page.github_username }}" target="_blank" rel="noopener">
      <img loading="lazy" decoding="async" src="https://ghchart.rshah.org/{{ page.github_username }}" alt="GitHub contribution graph" />
    </a>
  </section>

  <script>
    (function() {
      var username = '{{ page.github_username }}';
      var container = document.getElementById('pinnedRepos');

      fetch('https://pinned.berrysauce.dev/get/' + username)
        .then(function(res) { return res.json(); })
        .then(function(repos) {
          if (!repos || repos.length === 0) {
            container.innerHTML = '';
            return;
          }

          var reposToShow = repos.slice(0, 6);

          function renderRepo(repo) {
            var langColor = repo.languageColor || '#858585';
            var repoLink = 'https://github.com/' + repo.author + '/' + repo.name;
            var card = '<a href="' + repoLink + '" class="pinned-repo-card" target="_blank" rel="noopener noreferrer">';
            card += '<div class="pinned-repo-header">';
            card += '<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 1 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 0 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5v-9z"/></svg>';
            card += '<span class="pinned-repo-name">' + repo.name + '</span>';
            card += '</div>';
            if (repo.description) {
              card += '<p class="pinned-repo-desc">' + repo.description + '</p>';
            }
            card += '<div class="pinned-repo-meta">';
            if (repo.language) {
              card += '<span class="pinned-repo-lang"><span class="lang-dot" style="background:' + langColor + '"></span>' + repo.language + '</span>';
            }
            card += '<span class="pinned-repo-stars"><svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z"/></svg>' + repo.stars + '</span>';
            card += '</div>';
            card += '</a>';
            return card;
          }

          var html = '<div class="pinned-repos-wrapper">';
          reposToShow.forEach(function(repo) { html += renderRepo(repo); });
          reposToShow.forEach(function(repo) { html += renderRepo(repo); });
          html += '</div>';
          container.innerHTML = html;
        })
        .catch(function() {
          container.innerHTML = '';
        });
    })();
  </script>
{% endif %}

<!-- Featured Video -->
{% if page.youtube and page.youtube.url %}
  <section class="home-section">
    <h2 class="home-section-title">{{ page.youtube.title | default: "Featured Video" }}</h2>
    {% if page.youtube.quote %}
      <blockquote class="home-inspiration-quote">
        "{{ page.youtube.quote }}"
        {% if page.youtube.quote_author %}
          <cite>{{ page.youtube.quote_author }}</cite>
        {% endif %}
      </blockquote>
    {% endif %}
    <div class="video-wrapper">
      <iframe
        loading="lazy"
        src="{{ page.youtube.url }}"
        title="YouTube video player"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </section>
{% endif %}

<!-- Special Thanks -->
{% if page.special_thanks and page.special_thanks.size > 0 %}
  <section class="home-section home-thanks">
    <h2 class="home-section-title">Special Thanks</h2>
    <div class="credits-scroll-container">
      <div class="credits-scroll">
        {% for person in page.special_thanks %}
          <div class="thanks-item">
            <span class="thanks-name">{{ person.name }}</span>
          </div>
        {% endfor %}
        {% for person in page.special_thanks %}
          <div class="thanks-item">
            <span class="thanks-name">{{ person.name }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}
